# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron
CRON_SECRET=replace-me

# Integrations (server-only) - set in Vercel/Supabase Vault for prod
ANTHROPIC_ADMIN_KEY=
# Regular Anthropic API key (sk-ant-api03-...) for the card-cost AI classifier.
# Distinct from ANTHROPIC_ADMIN_KEY (usage reporting). If unset, CSV import still
# works but unknown merchants are left for manual review instead of AI-classified.
ANTHROPIC_API_KEY=
OPENAI_ADMIN_KEY=
OPENAI_ADMIN_KEY_HAUS=
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
GITHUB_TOKEN=
# Vercel project-linking (per-project spend needs the usage export)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
# Google Cloud Billing → BigQuery export (Vertex AI / Gemini spend).
# Paste the whole service-account JSON as GOOGLE_CREDENTIALS_JSON (not a path),
# and the fully-qualified export table as GOOGLE_BILLING_TABLE. Label resources
# with `haus_project=<projects.slug>` so spend attributes correctly.
GOOGLE_CREDENTIALS_JSON=
GOOGLE_BILLING_TABLE=
